# Imported HUD source bundles are reference material and assets. Preserve their
# original bytes instead of normalizing or whitespace-checking them.
hud_profiles/*/assets/** -text -diff

*.png binary
*.jpg binary
*.jpeg binary
*.ttf binary
*.ico binary
*.exe binary
*.dll binary
